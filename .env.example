# LLM provider: anthropic | openai | windsurf | mock
LLM_PROVIDER=mock
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
# Endpoint OpenAI-compatibile opzionale. Usato dai provider "openai" e "windsurf".
# Per Windsurf/SWE punta a un gateway OpenAI-compatibile, es:
#   LLM_PROVIDER=windsurf
#   LLM_BASE_URL=http://localhost:3003/v1
#   OPENAI_API_KEY=<chiave-del-gateway>
#   LLM_MODEL=cognition-swe-1.5
LLM_BASE_URL=
LLM_MODEL=claude-3-5-sonnet-20241022

# Blocco 1 - microservizio analitico
BLOCK1_BASE_URL=http://localhost:7000
BLOCK1_API_KEY=

# App
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO

MAX_TOOL_TURNS=5
